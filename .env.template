# HTX Trading Platform - Environment Configuration Template
# Copy this file to .env and fill in your values
# 
# SECURITY NOTE: This file contains sensitive information. 
# For production use, all secrets should be stored in Google Secret Manager.

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Environment (dev, staging, prod)
ENV=dev

# Application settings
APP_NAME="HTX Trading Analysis API"
VERSION="1.0.0"
DEBUG=true

# Server settings
API_HOST=0.0.0.0
API_PORT=8004

# CORS settings (comma-separated URLs)
ALLOWED_HOSTS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite (default for personal use)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
DATABASE_ECHO=false

# PostgreSQL (optional, for advanced users)
# DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/htx_db

# ============================================================================
# HTX EXCHANGE API CREDENTIALS
# ============================================================================
# Obtain these from: https://www.htx.com/en-us/apikey/

# HTX API Key (required for live trading data)
HTX_API_KEY=your_htx_api_key_here

# HTX API Secret (required for authenticated requests)
HTX_API_SECRET=your_htx_api_secret_here

# HTX Sub-account UID (optional, leave empty for main account)
HTX_SUBUID=

# HTX API Base URL (change only if using different region)
HTX_BASE_URL=https://api.huobi.pro

# ============================================================================
# ENCRYPTION SETTINGS
# ============================================================================
# Generate a new encryption key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

ENCRYPTION_KEY=your_generated_encryption_key_here

# ============================================================================
# OPENAI API CONFIGURATION
# ============================================================================
# Required for ML analytics and natural language features
# Get your key from: https://platform.openai.com/api-keys

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.1

# ============================================================================
# 3COMMAS API CONFIGURATION (Optional)
# ============================================================================
# For portfolio synchronization and advanced trading features
# Get your keys from: https://3commas.io/api_access

THREECOMMAS_API_KEY=your_3commas_api_key_here
THREECOMMAS_API_SECRET=your_3commas_api_secret_here
THREECOMMAS_BASE_URL=https://api.3commas.io/public/api

# ============================================================================
# GOOGLE CLOUD PLATFORM CONFIGURATION
# ============================================================================

# GCP Project ID (required for cloud features)
GCP_PROJECT_ID=your_gcp_project_id_here

# GCP Region
GCP_REGION=us-central1

# Service Account Key Path (relative to project root)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json

# Use default credentials when running in GCP
GCP_USE_DEFAULT_CREDENTIALS=false

# ============================================================================
# GOOGLE CLOUD STORAGE
# ============================================================================

# Primary bucket for trading data
GCP_STORAGE_BUCKET=htx-trading-data

# Temporary bucket for processing
GCP_STORAGE_TEMP_BUCKET=htx-trading-temp

# Storage prefixes
GCP_STORAGE_UPLOAD_PREFIX=uploads/
GCP_STORAGE_PROCESSED_PREFIX=processed/

# ============================================================================
# GOOGLE PUB/SUB TOPICS
# ============================================================================

# Topic for trade ingestion events
PUBSUB_TRADE_INGESTED_TOPIC=trade-ingested

# Topic for parsing completion events
PUBSUB_PARSING_COMPLETED_TOPIC=parsing-completed

# Topic for ML model inference requests
PUBSUB_MODEL_INFERENCE_TOPIC=model-inference

# Topic for HTX synchronization events
PUBSUB_HTX_SYNC_TOPIC=htx-sync-completed

# ============================================================================
# GOOGLE BIGQUERY
# ============================================================================

# BigQuery dataset for analytics
BIGQUERY_DATASET=trading_analytics

# Table names
BIGQUERY_TRADES_TABLE=trades
BIGQUERY_DEPOSITS_TABLE=deposits
BIGQUERY_WITHDRAWALS_TABLE=withdrawals
BIGQUERY_PREDICTIONS_TABLE=ml_predictions

# ============================================================================
# VERTEX AI CONFIGURATION
# ============================================================================

# Vertex AI region
VERTEX_AI_LOCATION=us-central1

# ML staging bucket
VERTEX_AI_STAGING_BUCKET=htx-ml-staging

# Model display name
VERTEX_AI_MODEL_DISPLAY_NAME=htx-trading-model

# ============================================================================
# CLOUD SCHEDULER
# ============================================================================

# Scheduler location
SCHEDULER_LOCATION=us-central1

# Time zone for scheduled jobs
SCHEDULER_TIME_ZONE=UTC

# HTX sync schedule (every hour)
SCHEDULER_HTX_SYNC_SCHEDULE=0 */1 * * *

# Data processing schedule (daily at 2 AM)
SCHEDULER_DATAFLOW_SCHEDULE=0 2 * * *

# Model retraining schedule (weekly on Sunday)
SCHEDULER_MODEL_RETRAIN_SCHEDULE=0 0 * * 0

# ============================================================================
# FILE PROCESSING SETTINGS
# ============================================================================

# Upload directory (relative to project root)
UPLOAD_DIR=./data/raw

# Processed files directory
PROCESSED_DIR=./data/processed

# Maximum file size (50MB)
MAX_FILE_SIZE=52428800

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=.csv,.xlsx,.xls

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/htx_project.log

# ============================================================================
# REDIS CONFIGURATION (Optional)
# ============================================================================
# Required for background tasks and caching

REDIS_URL=redis://localhost:6379

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# JWT secret for authentication (generate a strong secret)
JWT_SECRET=your_jwt_secret_here_change_this_in_production

# JWT token expiration (in minutes)
JWT_EXPIRE_MINUTES=43200

# ============================================================================
# ANALYTICS SETTINGS
# ============================================================================

# Default currency for calculations
DEFAULT_CURRENCY=USD

# Application timezone
TIMEZONE=UTC

# ============================================================================
# BACKGROUND TASKS
# ============================================================================

# Enable background task processing
ENABLE_BACKGROUND_TASKS=true

# Task queue name
TASK_QUEUE_NAME=htx_tasks

# ============================================================================
# RATE LIMITING
# ============================================================================

# API rate limit per minute
RATE_LIMIT_PER_MINUTE=100

# ============================================================================
# MACHINE LEARNING SETTINGS
# ============================================================================

# ML model cache TTL (seconds)
ML_MODEL_CACHE_TTL=3600

# Embedding dimensions for vector search
EMBEDDING_DIMENSIONS=1536

# Vector similarity threshold
VECTOR_SIMILARITY_THRESHOLD=0.8

# Hardware settings for local ML models
ML_DEVICE=cpu
LOAD_IN_4BIT=true
TORCH_DTYPE=float16

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Enable detailed SQL logging
# DATABASE_ECHO=true

# Enable debug mode
# DEBUG=true

# Additional CORS origins for development
# ALLOWED_HOSTS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://192.168.1.100:3000