# Markdown linting configuration

# Rule configuration
default: true

# Line length
MD013:
  line_length: 100
  code_blocks: false
  tables: false
  headings: false

# Trailing spaces
MD009:
  br_spaces: 2
  list_item_empty_lines: false
  strict: false

# Multiple consecutive blank lines
MD012:
  maximum: 2

# Line length in code blocks
MD013:
  code_blocks: false

# Dollar signs used before commands without showing output
MD014: false

# No trailing punctuation in headers
MD026:
  punctuation: ".,;:!?"

# Multiple headers with same content
MD024:
  allow_different_nesting: true

# Inline HTML
MD033:
  allowed_elements: [br, sub, sup, kbd, mark]

# Emphasis used instead of header
MD036: false

# Spaces inside emphasis markers
MD037: true

# Spaces inside code span elements
MD038: true

# Spaces inside link text
MD039: true

# Fenced code blocks should be surrounded by blank lines
MD031: true

# Lists should be surrounded by blank lines
MD032: true

# Bare URL used
MD034: false

# Horizontal rule style
MD035:
  style: "---"

# Emphasis style
MD049:
  style: "asterisk"

# Strong style
MD050:
  style: "asterisk"