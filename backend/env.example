# --- Backend ---
ENV=dev
API_HOST=0.0.0.0
API_PORT=8000

# DB: для начала можно SQLite
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# Для Postgres (пример):
# DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/htx

# HTX (Huobi)
HTX_API_KEY=changeme
HTX_API_SECRET=changeme
HTX_SUBUID=
HTX_BASE_URL=https://api.huobi.pro

# 3Commas (работаем через httpx)
THREECOMMAS_API_KEY=
THREECOMMAS_API_SECRET=
THREECOMMAS_BASE_URL=https://api.3commas.io/public/api

# Парсинг/загрузка файлов
UPLOAD_DIR=./data/raw
PROCESSED_DIR=./data/processed

# Безопасность (если нужна авторизация)
JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=43200
